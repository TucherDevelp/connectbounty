# Kopiere diese Datei zu .env.local und ersetze die Werte aus
# https://supabase.com/dashboard/project/<ref>/settings/api

# ── Supabase ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon

# Server-only: niemals NEXT_PUBLIC_ prefixen!
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role

# Direkter Postgres-Zugang (für scripts/db-migrate.mjs).
# Supabase → Settings → Database → Connection string → URI (Mode: Session, Port 5432).
# Beispiel:
# postgresql://postgres.<project-ref>:<PASSWORT>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── App ────────────────────────────────────────────────────────────────
# Wird für OAuth-Redirects, Mail-Links etc. genutzt.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── KYC ────────────────────────────────────────────────────────────────
# "mock"      – kein externer Provider, simuliert Approval per Dev-Button
# "ballerine" – Open-Source-KYC via Ballerine (https://github.com/ballerine-io/ballerine)
KYC_PROVIDER=mock
KYC_WEBHOOK_SECRET=change-me-in-prod

# Ballerine (nur falls KYC_PROVIDER=ballerine).
# BALLERINE_API_URL=https://api.ballerine.local
# BALLERINE_API_KEY=
# BALLERINE_WORKFLOW_ID=
# BALLERINE_WEBHOOK_SECRET=
